# ============ Cardia auto-pull — credential ============
# Copy file này thành .env (cùng thư mục) rồi điền. KHÔNG commit .env.

# --- Meta (Marketing API) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxx

# --- Adjust (Reporting API) ---
ADJUST_API_TOKEN=
# Dán phần URL SAU "https://automate.adjust.com" lấy từ Datascape → Copy API call.
# Ví dụ (xoá phần token nếu có trong url, script tự thêm header):
# ADJUST_REPORT_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=day,campaign,country&metrics=installs,ad_revenue,cost,roas_d0,roas_d7,retention_rate_d1,retention_rate_d7,sessions,daus,waus
ADJUST_REPORT_QUERY=

# (Tùy chọn) Query creative-level — retention/ROAS theo từng creative. Để trống nếu chưa cần.
# ADJUST_CREATIVE_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=campaign,adgroup,creative,country&metrics=installs,cost,ad_revenue,roas_d7,retention_rate_d1,retention_rate_d7

# --- Khoảng thời gian (tùy chọn; mặc định từ 13/06 → hôm nay) ---
SINCE=2026-06-13
# UNTIL=2026-06-28
