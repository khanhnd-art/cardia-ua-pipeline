# ============ Cardia auto-pull — credential ============
# Copy file này thành .env (cùng thư mục) rồi điền. KHÔNG commit .env.

# --- Meta (Marketing API) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxx

# (Tùy chọn) Account dùng CHUNG cho cả Cardia + Saya (campaign trộn 2 app trong cùng 1 account,
# cùng BM). Script tự lọc theo campaign_name (lọc phía Python, sau khi fetch): trang Cardia chỉ
# nhận campaign chứa "Cardia_"; trang Saya loại campaign chứa "Cardia_" (Saya không có prefix
# tên cố định — Say_, Eden_...) — KHÔNG ảnh hưởng account riêng của từng app ở trên.
# META_SHARED_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxx
META_SHARED_AD_ACCOUNT_ID=

# --- Adjust (Reporting API) ---
ADJUST_API_TOKEN=
# Dán phần URL SAU "https://automate.adjust.com" lấy từ Datascape → Copy API call.
# QUAN TRỌNG: luôn kèm &utc_offset=-07:00 (reporting TZ GMT-7 — khớp Datascape + ngày Meta;
# API mặc định bucket ngày theo UTC → số ngày sẽ lệch ~7h nếu thiếu) và dimension `network`
# (để script lọc bỏ Organic — dashboard chỉ đo paid UA).
# Ví dụ (xoá phần token nếu có trong url, script tự thêm header):
# ADJUST_REPORT_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=day,campaign,country,network&metrics=installs,ad_revenue,cost,roas_d0,roas_d7,retention_rate_d1,retention_rate_d7,sessions,daus,waus&utc_offset=-07:00
ADJUST_REPORT_QUERY=

# (Tùy chọn) Query creative-level — retention/ROAS theo từng creative. Để trống nếu chưa cần.
# ADJUST_CREATIVE_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=campaign,adgroup,creative,country&metrics=installs,cost,ad_revenue,roas_d7,retention_rate_d1,retention_rate_d7

# (Tùy chọn) Query cho app SAYA — sinh trang saya.html (Adjust + Meta account riêng).
# utc_offset=%2B07:00 KHỚP account Meta Saya chính (act_1636134540360437, Asia/Ho_Chi_Minh GMT+7).
# Cost TikTok nằm sẵn trong Adjust (cùng bucket với revenue nên offset nào cũng tự nhất quán;
# chỉ lệch nhẹ khi so daily với TikTok Ads Manager UTC+8).
# ⚠️ Dấu "+" PHẢI encode %2B, để trần sẽ bị hiểu là dấu cách.
# ADJUST_SAYA_QUERY=/reports-service/report?app_token__in=SAYA_APPTOKEN&dimensions=day,campaign,country,network&metrics=installs,cost,ad_revenue,roas_d0,roas_d7,retention_rate_d1,retention_rate_d7,sessions,daus,waus&utc_offset=%2B07:00
ADJUST_SAYA_QUERY=

# (Tùy chọn) Ad account Meta của SAYA — thêm bảng Campaign/Creative (CTR, hook-rate) vào trang Saya.
# Cùng system-user token ở trên (thêm account vào system user với View performance là thấy).
# Nhận NHIỀU account cách nhau dấu phẩy (giai đoạn chuyển account): data gộp chung, currency
# từng account tự phát hiện qua API (VND/USD) — dashboard tự quy đổi.
# META_SAYA_AD_ACCOUNT_ID=act_3280909035510133,act_1636134540360437
META_SAYA_AD_ACCOUNT_ID=

# --- Khoảng thời gian (tùy chọn; mặc định từ 13/06 → hôm nay) ---
SINCE=2026-06-13
# UNTIL=2026-06-28
