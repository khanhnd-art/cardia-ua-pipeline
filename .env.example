# ============ Cardia auto-pull — credential ============
# Copy file này thành .env (cùng thư mục) rồi điền. KHÔNG commit .env.

# --- Meta (Marketing API) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxx

# --- Adjust (Reporting API) ---
ADJUST_API_TOKEN=
# Dán phần URL SAU "https://automate.adjust.com" lấy từ Datascape → Copy API call.
# QUAN TRỌNG: luôn kèm &utc_offset=-07:00 (reporting TZ GMT-7 — khớp Datascape + ngày Meta;
# API mặc định bucket ngày theo UTC → số ngày sẽ lệch ~7h nếu thiếu) và dimension `network`
# (để script lọc bỏ Organic — dashboard chỉ đo paid UA).
# Ví dụ (xoá phần token nếu có trong url, script tự thêm header):
# ADJUST_REPORT_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=day,campaign,country,network&metrics=installs,ad_revenue,cost,roas_d0,roas_d7,retention_rate_d1,retention_rate_d7,sessions,daus,waus&utc_offset=-07:00
ADJUST_REPORT_QUERY=

# (Tùy chọn) Query creative-level — retention/ROAS theo từng creative. Để trống nếu chưa cần.
# ADJUST_CREATIVE_QUERY=/reports-service/report?app_token__in=APPTOKEN&dimensions=campaign,adgroup,creative,country&metrics=installs,cost,ad_revenue,roas_d7,retention_rate_d1,retention_rate_d7

# (Tùy chọn) Query cho app SAYA (TikTok Ads) — sinh trang saya.html, toàn bộ số từ Adjust
# (TikTok đẩy ad spend sang Adjust qua partner link nên KHÔNG cần TikTok API cho v1).
# LƯU Ý: Saya khớp ngày theo ad account ZAS 01 (UTC+8) → utc_offset=%2B08:00
# (dấu "+" PHẢI encode thành %2B, để trần "+" sẽ bị hiểu là dấu cách → API lỗi).
# ADJUST_SAYA_QUERY=/reports-service/report?app_token__in=SAYA_APPTOKEN&dimensions=day,campaign,country,network&metrics=installs,cost,ad_revenue,roas_d0,roas_d7,retention_rate_d1,retention_rate_d7,sessions,daus,waus&utc_offset=%2B08:00
ADJUST_SAYA_QUERY=

# --- Khoảng thời gian (tùy chọn; mặc định từ 13/06 → hôm nay) ---
SINCE=2026-06-13
# UNTIL=2026-06-28
